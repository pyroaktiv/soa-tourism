          }
        }
      }
    },
    "v1IsFollowingResponse": {
      "type": "object",
      "properties": {
        "isFollowing": {
          "type": "boolean"
        }
      }
    },
    "v1Recommendation": {
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "mutualFollows": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "v1UnfollowResponse": {
      "type": "object",
      "properties": {
        "success": {
          "type": "boolean"
        }
      }
    }
  }
}
